# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_GUILD_ID=your-discord-guild-id

# OpenAI (required for Codex / assistant interpreter)
OPENAI_API_KEY=

# Codex
CODEX_MODEL=gpt-5.4
CODEX_JS_PATH=
CODEX_NODE_PATH=
MAVERICK_INSTANCE_ID=windows
# Optional override for Claude Code. On Windows this is often something like:
# CLAUDE_PATH=C:\Users\<you>\.local\bin\claude.exe
# or CLAUDE_PATH=C:\Users\<you>\AppData\Roaming\npm\claude.cmd
CLAUDE_PATH=

# Database
# Windows companion mode should use the Linux-owned state API through an SSH tunnel.
STATE_BACKEND=sqlite
MAVERICK_STATE_URL=
MAVERICK_STATE_TOKEN=
# When STATE_BACKEND=remote and MAVERICK_STATE_URL is behind Cloudflare Access (service token).
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=
MAVERICK_STATE_TIMEOUT_MS=30000
# Used only when STATE_BACKEND=sqlite, such as isolated local dev or offline recovery.
DATABASE_PATH=./data/orchestrator.db

# Dashboard HTTP API (browser CORS + optional Bearer)
# Comma-separated origins, e.g. https://brookswimer.com,https://www.brookswimer.com
MAVERICK_DASHBOARD_ALLOWED_ORIGIN=
MAVERICK_DASHBOARD_TOKEN=

# Server
HTTP_PORT=3847
LOG_LEVEL=info

# Safety defaults
DEFAULT_SANDBOX_MODE=workspace-write
DEFAULT_APPROVAL_POLICY=on-request
MAX_CONCURRENT_WORKSTREAMS=6
MAX_CONCURRENT_TURNS_PER_WORKSTREAM=1

# Assistant
ASSISTANT_ALLOWED_PHONE_NUMBERS=
ASSISTANT_ALLOWED_DISCORD_USER_IDS=

# Twilio SMS (optional fallback, not required for Discord assistant mode)
ASSISTANT_TWILIO_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
