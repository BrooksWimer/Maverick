# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_GUILD_ID=your-discord-guild-id

# Codex
CODEX_MODEL=gpt-5.4
CODEX_JS_PATH=
CODEX_NODE_PATH=

# Database
DATABASE_PATH=./data/orchestrator.db

# Server
HTTP_PORT=3847
LOG_LEVEL=info

# Safety defaults
DEFAULT_SANDBOX_MODE=workspace-write
DEFAULT_APPROVAL_POLICY=on-request
MAX_CONCURRENT_WORKSTREAMS=6
MAX_CONCURRENT_TURNS_PER_WORKSTREAM=1

# Assistant
ASSISTANT_ALLOWED_PHONE_NUMBERS=
ASSISTANT_ALLOWED_DISCORD_USER_IDS=

# Twilio SMS (optional fallback, not required for Discord assistant mode)
ASSISTANT_TWILIO_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
