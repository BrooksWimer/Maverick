# Maverick Linux service environment
NODE_ENV=production
MAVERICK_INSTANCE_ID=linux

# Discord
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=

# OpenAI (required for Codex / assistant interpreter)
OPENAI_API_KEY=

# Codex
CODEX_MODEL=gpt-5.4
CODEX_JS_PATH=/usr/local/lib/node_modules/@openai/codex/bin/codex.js
CODEX_NODE_PATH=/usr/bin/node

# Database
STATE_BACKEND=sqlite
DATABASE_PATH=/var/lib/maverick/orchestrator.db
MAVERICK_STATE_TOKEN=
MAVERICK_STATE_URL=
MAVERICK_STATE_TIMEOUT_MS=30000

# Browser command center (comma-separated). Must echo the site origin when using credentialed fetches.
MAVERICK_DASHBOARD_ALLOWED_ORIGIN=https://maverick.brookswimer.com
MAVERICK_DASHBOARD_TOKEN=

# Server
HTTP_PORT=3847
LOG_LEVEL=info

# Safety defaults
DEFAULT_SANDBOX_MODE=workspace-write
DEFAULT_APPROVAL_POLICY=on-request
MAX_CONCURRENT_WORKSTREAMS=6
MAX_CONCURRENT_TURNS_PER_WORKSTREAM=1

# Assistant
ASSISTANT_ALLOWED_PHONE_NUMBERS=
ASSISTANT_ALLOWED_DISCORD_USER_IDS=

# Twilio SMS (optional fallback, not required for Discord assistant mode)
ASSISTANT_TWILIO_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
